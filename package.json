{
    "name": "imdb-waf-resolver",
    "version": "1.4.0",
    "private": true,
    "description": "Microservicio Node + Chromium que navega a IMDb y devuelve el ld+json, resolviendo transparentemente el challenge de AWS WAF",
    "main": "server.js",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "start": "node server.js",
        "dev": "node server.js",
        "install-chromium": "playwright install chromium",
        "install-deps-linux": "playwright install-deps chromium"
    },
    "dependencies": {
        "@fastify/rate-limit": "^9.1.0",
        "fastify": "^4.28.1",
        "playwright": "^1.47.0",
        "playwright-extra": "^4.3.6",
        "puppeteer-extra-plugin-stealth": "^2.11.2"
    }
}
